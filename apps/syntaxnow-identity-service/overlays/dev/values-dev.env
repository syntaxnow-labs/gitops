APP_NAME=syntaxnow-identity-service
APP_ENV=dev
SPRING_PROFILES_ACTIVE=dev
KEYCLOAK_URL=https://auth.syntaxnow.com
KEYCLOAK_REALM=syntaxnow
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_CLIENT_ID=syntaxnow-identity-service

REDIS_HOST=10.0.0.80
REDIS_PORT=6379

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=mailer@syntaxnow.com

APP_CORS_ALLOWED_ORIGINS=http://localhost:*,https://localhost:*,https://*.syntaxnow.com
APP_MAIL_FROM=no-reply@syntaxnow.com

LOG_LEVEL=INFO
